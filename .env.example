# ─────────────────────────────────────────────────────────────────────────────
# Pensée — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values below.
# Variables prefixed with EXPO_PUBLIC_ are embedded into the app bundle
# and visible to the client. Do NOT put secrets in EXPO_PUBLIC_ vars.
# ─────────────────────────────────────────────────────────────────────────────

# URL of your PocketBase instance (required)
EXPO_PUBLIC_POCKETBASE_URL=https://your-pocketbase-instance.com
